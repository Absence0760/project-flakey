{
  "info": {
    "name": "Flakey API Tests",
    "_postman_id": "flakey-api-tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health returns 200",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login rejects invalid credentials",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"bad@example.com\",\"password\":\"wrong\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects invalid login', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /stats requires auth",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/stats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401 without token', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Input Validation",
      "item": [
        {
          "name": "POST /runs rejects empty body",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/runs",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects empty payload', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 401, 422]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /runs rejects SQL injection in suite name",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/runs",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"meta\":{\"suite_name\":\"'; DROP TABLE runs;--\",\"reporter\":\"junit\"},\"stats\":{\"total\":0,\"passed\":0,\"failed\":0,\"skipped\":0,\"pending\":0,\"duration_ms\":0},\"specs\":[]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Handles SQL injection safely', function () {",
                  "  pm.expect(pm.response.code).to.not.equal(500);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Flaky",
      "description": "Intentionally flaky requests used to exercise Better Testing's flaky-detection feature. Fails ~30% of the time.",
      "item": [
        {
          "name": "GET /health (intentionally flaky)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Intentional ~30% failure to exercise flaky-test detection in Better Testing.",
                  "pm.test('flaky: random failure (intentional demo)', function () {",
                  "  if (Math.random() < 0.3) {",
                  "    pm.expect.fail('intentional flaky failure — expected ~30% of the time');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
