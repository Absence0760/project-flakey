{
  "name": "@flakeytesting/example-webdriverio",
  "private": true,
  "type": "module",
  "comments": {
    "deps": "To use published npm packages, replace link: entry with: \"@flakeytesting/webdriverio-reporter\": \"latest\""
  },
  "scripts": {
    "test:smoke": "SUITE=smoke wdio run wdio.conf.ts",
    "test:sanity": "SUITE=sanity wdio run wdio.conf.ts",
