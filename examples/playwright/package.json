{
  "name": "@flakeytesting/example-playwright",
  "private": true,
  "comments": {
    "deps": "To use published npm packages, replace link: entry with: \"@flakeytesting/playwright-reporter\": \"latest\""
  },
  "scripts": {
    "test:smoke": "SUITE=smoke playwright test --config playwright.config.ts",
    "test:sanity": "SUITE=sanity playwright test --config playwright.config.ts",
    "test:regression": "SUITE=regression playwright test --config playwright.config.ts",
    "test:all": "SUITE=smoke playwright test; SUITE=sanity playwright test; SUITE=regression playwright test"
  },
  "devDependencies": {
    "@flakeytesting/playwright-reporter": "link:../../packages/flakey-playwright-reporter",
    "@playwright/test": "latest",
    "typescript": "latest"
  }
}
