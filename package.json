{
  "name": "project-flakey",
  "private": true,
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:seed": "cd backend && npm run seed",
    "storage:up": "docker compose --profile storage up -d minio minio-init",
    "storage:down": "docker compose rm -sf minio minio-init",
    "webhooks:up": "docker compose --profile integrations up -d webhook-sink",
    "webhooks:down": "docker compose rm -sf webhook-sink",
    "ai:up": "docker compose --profile ai up -d",
    "ai:down": "docker compose rm -sf ollama ollama-pull",
    "idp:up": "docker compose --profile idp up -d keycloak",
    "idp:down": "docker compose rm -sf keycloak",
    "idp:reset": "docker compose rm -sf keycloak && docker compose --profile idp up -d keycloak",
    "idp:scim:up": "docker compose --profile idp-scim up -d",
    "idp:scim:down": "docker compose --profile idp-scim rm -sf",
    "idp:scim:reset": "docker compose --profile idp-scim down -v && docker compose --profile idp-scim up -d",
    "services:up": "docker compose --profile storage --profile integrations up -d",
    "services:down": "docker compose down",
    "infra:preflight": "infra/scripts/preflight.sh",
    "infra:seed-image": "infra/scripts/seed-first-image.sh",
    "setup": "pnpm install && pnpm install:backend && pnpm install:frontend",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && pnpm install --ignore-workspace",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && pnpm dev",
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:all": "docker compose up -d --wait && pnpm dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && pnpm build",
    "build:packages": "pnpm -r --filter \"@flakeytesting/*\" build",
    "build": "pnpm build:packages && pnpm build:backend && pnpm build:frontend",
    "check:backend": "cd backend && npx tsc --noEmit",
    "check:frontend": "cd frontend && pnpm check",
    "check": "pnpm check:backend && pnpm check:frontend",
    "openapi:generate": "cd backend && npm run openapi:generate",
    "openapi:check": "pnpm openapi:generate && git diff --exit-code -- frontend/src/lib/api-generated.ts",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && pnpm test",
    "test:packages": "pnpm -r --workspace-concurrency=1 --filter \"@flakeytesting/*\" --if-present test",
    "test:examples": "cd examples/shared && pnpm install --ignore-workspace && pnpm test",
    "test:e2e": "cd frontend && pnpm test:e2e",
    "test": "pnpm test:backend && pnpm test:packages && pnpm test:frontend",
    "upload": "cd packages/flakey-cli && node dist/index.js"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.25",
      "ip-address": ">=10.1.1",
      "serialize-javascript": ">=7.0.5",
      "uuid": ">=13.0.1",
      "diff": ">=8.0.3",
      "systeminformation": ">=5.31.6",
      "brace-expansion": ">=5.0.6",
      "qs": ">=6.15.2",
      "tmp": ">=0.2.6",
      "ws": ">=8.21.0",
      "form-data": ">=4.0.6",
      "js-yaml": ">=4.2.0",
      "undici": ">=7.28.0",
      "esbuild": ">=0.28.1",
      "@babel/core": ">=7.29.6 <8.0.0"
    }
  }
}
