# Local-development defaults for the backend. This file is COMMITTED and
# loaded automatically by `npm run dev` (--env-file=.env.development), so a
# fresh clone runs with no setup. It must never contain real secrets.
#
# Personal overrides (real JWT_SECRET, AI keys, an S3/Ollama block you don't
# want to share) go in `.env.development.local` — gitignored, loaded last so it
# wins. Don't edit this file for machine-local tweaks; it'll dirty the tree.

# Database (matches docker-compose defaults)
DB_HOST=localhost
DB_PORT=5432
DB_USER=flakey_app
DB_PASSWORD=flakey_app
DB_NAME=flakey

# Server
PORT=3000
NODE_ENV=development

# Auth — JWT_SECRET is REQUIRED in production; the boot guard refuses
# to start without it. Generate one per environment with:
#   openssl rand -hex 32
# Leave JWT_SECRET unset in local dev — the dev-only fallback fires
# automatically when NODE_ENV != production.
# JWT_SECRET=
# Encryption key for AES-256-GCM (Jira / PagerDuty tokens). REQUIRED
# in production. Generate with `openssl rand -hex 32`. Leave unset in
# local dev — the code passes through plaintext when no key is set.
# FLAKEY_ENCRYPTION_KEY=
# Optional previous key for rotation. When set, decryptSecret() falls
# back to this key if the primary fails to authenticate a ciphertext.
# Never used for new writes. See backend/docs/integrations.md for the
# dual-key rotation procedure.
# FLAKEY_ENCRYPTION_KEY_OLD=
# ALLOW_REGISTRATION=true   # Uncomment to enable open self-registration; default is invite-only

# CORS (comma-separated origins, only enforced when NODE_ENV=production)
# Dev frontend listens on 7778; backend on 3000.
CORS_ORIGINS=http://localhost:7778,http://localhost:3000

# --- Enterprise SSO (Phase 14) ---
# OFF by default. Set FLAKEY_SSO_ENABLED=true to expose the OIDC/SAML login
# flow (/auth/sso/*) and the admin config API (/sso/config). Per-org config is
# still required after the flag is on. Prototype against the bundled Keycloak:
#   pnpm idp:up   (realm `flakey`, issuer http://localhost:8081/realms/flakey)
# FLAKEY_SSO_ENABLED=true
# Public base URL of THIS backend — used to build the IdP redirect_uri
# (<PUBLIC_API_URL>/auth/sso/callback). Must be registered at the IdP.
# Defaults to http://localhost:3000 in dev.
# PUBLIC_API_URL=http://localhost:3000
# FRONTEND_URL is reused for the post-login redirect (defaults to :7778).
# Note: "SSO required" enforcement is per-org and OFF by default, so local dev
# (admin@example.com) is never forced through an IdP unless you explicitly
# enable enforcement for an org in Settings -> Single sign-on.

# --- Audit-log SIEM export (Phase 16) ---
# OFF by default. The audit log is always hash-chained (verify via GET
# /audit/verify); this flag additionally enables EXPORT — durable, gap-free
# streaming of audit_log to a per-org HTTP (customer SIEM) or S3 destination,
# configured via the admin /audit/export API. When unset, the flusher no-ops
# and the /audit/export routes 404. To prototype locally, point an HTTP
# destination at the webhook echo sink (pnpm webhooks:up, :8080).
# FLAKEY_AUDIT_EXPORT_ENABLED=true

# --- Email (Mailpit) ---
# `docker compose up -d` starts Mailpit. The code already defaults to
# localhost:1025, so no config is needed; view captured mail at
# http://localhost:8025. Uncomment only to override.
# SMTP_HOST=localhost
# SMTP_PORT=1025
# EMAIL_FROM=Flakey <noreply@example.com>
# Disable the per-email verification-resend cooldown in local dev. The
# code default is 60s (prod-safe), but the verification e2e specs register
# then immediately resend to assert delivery, which the cooldown would
# suppress. Harmless to disable locally (no real inboxes to flood); the
# throttle itself is covered by register_verification_gate.smoke.test.ts.
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=0

# --- Artifact storage ---
# Default is local disk (uploads/). To exercise the S3 path against the
# bundled MinIO, start it with `docker compose --profile storage up -d`
# and uncomment the block below (creds match docker-compose.yml).
# STORAGE=s3
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
# S3_BUCKET=flakey-artifacts
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# --- AI analysis (optional) ---
# Off unless configured. AI is instance-wide (not per-org): once set,
# isAIEnabled() is true for every org. For a fully local model via Ollama
# (OpenAI-compatible), start the server with `pnpm ai:up` (dockerized; pulls
# llama3.2 on first run) or a native `ollama serve`, then set:
# AI_PROVIDER=openai
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=llama3.2
# For Anthropic instead: AI_PROVIDER=anthropic + ANTHROPIC_API_KEY=sk-...

# --- Webhooks (local sink) ---
# `docker compose --profile integrations up -d` starts an echo sink on
# :8080. Point a webhook target at http://localhost:8080 and inspect
# payloads via `docker compose logs -f webhook-sink`. Dev already allows
# private targets; production would need the next line:
# WEBHOOK_ALLOW_PRIVATE_TARGETS=true
