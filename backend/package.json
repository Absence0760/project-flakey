{
  "name": "flakey-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "seed": "tsx src/seed.ts",
    "rotate-keys": "tsx src/scripts/rotate-encryption-keys.ts",
