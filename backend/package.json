    "start": "node dist/index.js",
    "test": "node --import tsx --test src/tests/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@aws-sdk/client-s3": "^3.1045.0",
