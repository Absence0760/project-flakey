aws_region         = "ap-southeast-2"
environment        = "production"
app_name           = "flakey"
db_instance_class  = "db.t4g.micro"
allow_registration = false
budget_limit       = "150"
budget_alert_email = "you@example.com"

# Required: ACM certificate ARN for the ALB HTTPS listener.
# Must be in the same region as the ALB. Create one in the ACM
# console (https://console.aws.amazon.com/acm/home), wait for
# DNS validation to complete, then paste the ARN here.
acm_certificate_arn = "arn:aws:acm:ap-southeast-2:000000000000:certificate/00000000-0000-0000-0000-000000000000"

# REQUIRED: tighten the SPA's CSP connect-src to the API origin(s).
# The SvelteKit dashboard fetches the API from a different origin
# (typically the ALB DNS for the env's ECS service, or api.flakey.io
# behind a custom domain). Without this list, the CSP collapses to
# `connect-src 'self'` and every API call from the SPA is blocked.
# A non-empty list is enforced by a variable validation block.
csp_connect_src = ["https://api.flakey.io"]

# Optional cost-incurring toggles (defaults shown):
# rds_multi_az = true                  # set false on staging/dev to halve cost
# enable_performance_insights = false  # ~$7/mo
# enable_waf                  = false  # ~$9/mo + per-request
# enable_vpc_endpoints        = false  # ~$72/mo at 2 AZs
# enable_flow_logs            = false  # ~$5-15/mo

# Passwords are auto-generated and stored in AWS Secrets Manager.
# No manual secrets to configure.
