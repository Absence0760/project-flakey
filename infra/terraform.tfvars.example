# Self-hosters: copy this file to `terraform.tfvars` and replace every
# `<...>` placeholder with your own values. Every value below is a
# variable — there is no `flakey.io` hard-coding in the stack. The
# `app_name` controls every resource prefix (ECR repo, ECS cluster,
# log groups, etc.) so two different `app_name`s in two different
# AWS accounts won't collide.

aws_region         = "us-east-1"
environment        = "production"
app_name           = "<your-app-name>"           # e.g. "acme-tests" — used as the prefix for every named resource
db_instance_class  = "db.t4g.micro"
allow_registration = false                       # true = anyone can self-serve; false = invite-only
budget_limit       = "150"
budget_alert_email = "<you@your-domain.com>"

# Required: ACM certificate ARN for the ALB HTTPS listener.
# Must be in the same region as the ALB. Create one in the ACM
# console (https://console.aws.amazon.com/acm/home), wait for
# DNS validation to complete, then paste the ARN here.
acm_certificate_arn = "arn:aws:acm:<region>:<account-id>:certificate/<cert-id>"

# REQUIRED: the API origin(s) the SPA fetches from. The SvelteKit
# dashboard runs on a different origin from the API (CloudFront vs
# ALB), so the CSP must explicitly allow the API origin or every
# fetch from the dashboard fails. Set this to whatever public URL
# your ALB / API gateway lives at (custom domain via Route53 or the
# raw ALB DNS name). A non-empty list is enforced by a variable
# validation block — apply will refuse otherwise.
csp_connect_src = ["https://api.<your-domain>"]

# Optional cost-incurring toggles (defaults shown):
# rds_multi_az = true                  # set false on staging/dev to halve cost
# enable_performance_insights = false  # ~$7/mo
# enable_waf                  = false  # ~$9/mo + per-request
# enable_vpc_endpoints        = false  # ~$72/mo at 2 AZs
# enable_flow_logs            = false  # ~$5-15/mo

# Artifact storage lifecycle (S3 cost backstop behind per-org retention):
# artifact_retention_days     = 365    # hard expiry cap; keep >= your largest org retention_days
# artifact_ia_transition_days = 30     # days before transition to STANDARD_IA (S3 min 30)

# Passwords are auto-generated and stored in AWS Secrets Manager.
# No manual secrets to configure.
