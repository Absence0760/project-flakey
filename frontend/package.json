{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "better-testing",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev --port 7778",
		"build": "vite build",
		"preview": "vite preview --port 8888",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test --config=tests-e2e/playwright.config.ts",
		"test:e2e:ui": "playwright test --config=tests-e2e/playwright.config.ts --ui",
		"test:e2e:sso": "playwright test --config=tests-e2e/sso/playwright.sso.config.ts",
		"test:e2e:sso:app": "playwright test --config=tests-e2e/sso/playwright.sso-app.config.ts"
	},
	"devDependencies": {
		"@iconify-json/material-symbols": "1.2.76",
		"@playwright/test": "1.60.0",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.63.0",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@types/node": "25.9.1",
		"@vitest/ui": "4.1.8",
		"mdsvex": "^0.12.7",
		"normalize.css": "8.0.1",
		"svelte": "5.56.3",
		"svelte-check": "4.6.0",
		"typescript": "6.0.3",
		"unplugin-icons": "23.0.1",
		"vite": "8.0.16",
		"vitest": "4.1.8"
	},
	"type": "module",
	"dependencies": {
		"isomorphic-dompurify": "^3.15.0"
	}
}
