# Backend API URL
VITE_API_URL=http://localhost:3000

# Optional public site origin (e.g. https://flakey.io). When set, the /welcome
# landing page emits absolute canonical + Open Graph / Twitter card URLs so
# strict social scrapers unfurl correctly. Leave unset locally and for
# self-hosted builds — the page falls back to relative URLs.
# VITE_SITE_URL=
