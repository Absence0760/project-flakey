{
  "name": "@flakeytesting/cypress-snapshots",
  "version": "0.8.3",
  "description": "Cypress plugin that captures DOM snapshots at each command step for Flakey",
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    "./plugin": {
      "types": "./plugin.d.ts",
      "default": "./plugin.js"
    },
    "./support": {
      "types": "./support.d.ts",
      "default": "./support.js"
    },
    "./cucumber": {
      "types": "./cucumber.d.ts",
      "default": "./cucumber.js"
    }
  },
  "files": [
    "dist",
    "plugin.js",
    "plugin.d.ts",
    "support.js",
    "support.d.ts",
    "cucumber.js",
    "cucumber.d.ts"
  ],
  "peerDependenciesMeta": {
    "@badeball/cypress-cucumber-preprocessor": { "optional": true }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test 'src/tests/**/*.test.ts'"
  },
  "keywords": [
    "cypress",
    "testing",
    "dom-snapshots",
    "debugging",
    "flakey"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-cypress-snapshots"
  },
  "peerDependencies": {
    "cypress": ">=12.0.0",
    "@badeball/cypress-cucumber-preprocessor": ">=20.0.0"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.0",
    "@types/node": "^25.6.2",
    "cypress": "^15.0.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
