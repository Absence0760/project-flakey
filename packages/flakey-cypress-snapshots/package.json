{
  "name": "@flakeytesting/cypress-snapshots",
  "version": "0.8.1",
  "description": "Cypress plugin that captures DOM snapshots at each command step for Flakey",
  "type": "module",
  "main": "dist/plugin.js",
  "types": "plugin.d.ts",
  "exports": {
    "./plugin": "./plugin.js",
    "./support": "./support.js",
    "./cucumber": "./cucumber.js"
  },
  "files": [
    "dist",
    "plugin.js",
    "plugin.d.ts",
    "support.js",
    "support.d.ts",
    "cucumber.js",
    "cucumber.d.ts"
  ],
  "peerDependenciesMeta": {
    "@badeball/cypress-cucumber-preprocessor": { "optional": true }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "cypress",
    "testing",
    "dom-snapshots",
    "debugging",
    "flakey"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-cypress-snapshots"
  },
  "peerDependencies": {
    "cypress": ">=12.0.0",
    "@badeball/cypress-cucumber-preprocessor": ">=20.0.0"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.0",
    "@types/node": "^25.5.2",
    "cypress": "^15.0.0",
    "typescript": "^5.5.4"
  }
}
