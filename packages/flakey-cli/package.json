{
  "name": "@flakeytesting/cli",
  "version": "0.8.3",
  "description": "CLI tool for uploading test results to Flakey",
  "type": "module",
  "bin": {
    "flakey-upload": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test src/tests/*.test.ts"
  },
  "keywords": [
    "testing",
    "cypress",
    "playwright",
    "junit",
    "test-reporting",
    "ci"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-cli"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
