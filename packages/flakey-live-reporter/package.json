{
  "name": "@flakeytesting/live-reporter",
  "version": "0.8.3",
  "description": "Lightweight live test event reporter for Flakey — streams test progress in real-time",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./playwright": "./dist/playwright.js",
    "./mocha": "./dist/mocha.js",
    "./webdriverio": "./dist/webdriverio.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/tests/*.test.ts"
  },
  "keywords": [
    "testing",
    "reporter",
    "live",
    "flakey",
    "real-time"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-live-reporter"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
