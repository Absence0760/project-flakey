{
  "name": "@flakeytesting/live-reporter",
  "version": "0.9.0",
  "description": "Lightweight live test event reporter for Flakey — streams test progress in real-time",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.ts",
      "default": "./dist/playwright.js"
    },
    "./mocha": {
      "types": "./dist/mocha.d.ts",
      "default": "./dist/mocha.js"
    },
    "./webdriverio": {
      "types": "./dist/webdriverio.d.ts",
      "default": "./dist/webdriverio.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test 'src/tests/**/*.test.ts'"
  },
  "keywords": [
    "testing",
    "reporter",
    "live",
    "flakey",
    "real-time"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-live-reporter"
  },
  "homepage": "https://flakey.io",
  "bugs": {
    "url": "https://github.com/Absence0760/project-flakey/issues"
  },
  "author": "Flakey",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
