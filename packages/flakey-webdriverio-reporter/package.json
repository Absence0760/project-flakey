{
  "name": "@flakeytesting/webdriverio-reporter",
  "version": "0.9.0",
  "description": "WebdriverIO reporter for Flakey — uploads results, screenshots, and videos",
  "type": "module",
  "main": "dist/reporter.js",
  "types": "dist/reporter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    }
  },
  "files": [
