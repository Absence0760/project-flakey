  "keywords": [
    "webdriverio",
    "wdio",
    "testing",
    "reporter",
    "flakey"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-webdriverio-reporter"
  },
  "homepage": "https://flakey.io",
  "bugs": {
    "url": "https://github.com/Absence0760/project-flakey/issues"
  },
  "author": "Flakey",
  "peerDependencies": {
    "@wdio/reporter": ">=8.0.0",
    "@wdio/types": ">=8.0.0",
    "webdriverio": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@wdio/types": {
      "optional": true
    },
    "webdriverio": {
      "optional": true
    }
  },
  "dependencies": {
    "@flakeytesting/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@wdio/reporter": "^9.27.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
