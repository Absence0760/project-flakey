{
  "name": "@flakeytesting/core",
  "version": "0.8.3",
  "description": "Shared utilities for Flakey test reporting packages",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
