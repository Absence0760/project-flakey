{
  "name": "@flakeytesting/core",
  "version": "0.9.0",
  "description": "Shared utilities for Flakey test reporting packages",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test 'src/tests/**/*.test.ts'"
  },
  "keywords": [
    "testing",
    "test-reporting",
    "flakey"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-core"
  },
  "homepage": "https://flakey.io",
  "bugs": {
    "url": "https://github.com/Absence0760/project-flakey/issues"
  },
  "author": "Flakey",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
