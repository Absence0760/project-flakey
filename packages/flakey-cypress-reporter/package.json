{
  "name": "@flakeytesting/cypress-reporter",
  "version": "0.9.0",
  "description": "Cypress reporter for Flakey — uploads results, screenshots, videos, and DOM snapshots",
  "type": "module",
  "main": "dist/reporter.cjs",
  "types": "dist/reporter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./support": {
      "types": "./dist/support.d.ts",
      "default": "./dist/support.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-cjs.cjs",
    "test": "node --import tsx --test 'src/tests/**/*.test.ts'"
  },
  "keywords": [
    "cypress",
    "testing",
    "reporter",
    "flakey"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-cypress-reporter"
  },
  "homepage": "https://flakey.io",
  "bugs": {
    "url": "https://github.com/Absence0760/project-flakey/issues"
  },
  "author": "Flakey",
  "peerDependencies": {
    "cypress": ">=12.0.0",
    "@flakeytesting/cypress-snapshots": ">=0.1.0",
    "@flakeytesting/live-reporter": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@flakeytesting/cypress-snapshots": { "optional": true },
    "@flakeytesting/live-reporter": { "optional": true }
  },
  "dependencies": {
    "@flakeytesting/core": "workspace:*"
  },
  "devDependencies": {
    "@flakeytesting/cypress-snapshots": "workspace:*",
    "@flakeytesting/live-reporter": "workspace:*",
    "@types/mocha": "^10.0.0",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
