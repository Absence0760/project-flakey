{
  "name": "@flakeytesting/playwright-reporter",
  "version": "0.9.0",
  "description": "Playwright reporter for Flakey — uploads results, screenshots, and videos",
  "type": "module",
  "main": "dist/reporter.js",
  "types": "dist/reporter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test 'src/tests/**/*.test.ts'"
  },
  "keywords": [
    "playwright",
    "testing",
    "reporter",
    "flakey"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Absence0760/project-flakey.git",
    "directory": "packages/flakey-playwright-reporter"
  },
  "homepage": "https://flakey.io",
  "bugs": {
    "url": "https://github.com/Absence0760/project-flakey/issues"
  },
  "author": "Flakey",
  "peerDependencies": {
    "@playwright/test": ">=1.30.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "dependencies": {
    "@flakeytesting/core": "workspace:*",
    "@flakeytesting/playwright-snapshots": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
